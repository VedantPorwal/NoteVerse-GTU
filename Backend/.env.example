# ── Database (Neon PostgreSQL) ──────────────────────────
# Get these from https://console.neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Server ──────────────────────────────────────────────
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# ── Auth ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="your-secret-here"
JWT_EXPIRES_IN="7d"

# ── Seed (optional, run: npm run db:seed) ───────────────
SEED_ADMIN_EMAIL="admin@example.edu"
SEED_ADMIN_PASSWORD="change-me-8chars-min"
SEED_ADMIN_NAME="Admin"
